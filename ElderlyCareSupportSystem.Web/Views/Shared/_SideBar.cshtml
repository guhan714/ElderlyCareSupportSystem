<aside class="fixed left-0 top-0 h-screen w-72 bg-[#0B1120] border-r border-white/5 flex flex-col shadow-2xl">

  <!-- Logo -->
  <div class="h-16 flex items-center gap-3 px-6 border-b border-white/5">
    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-violet-800 flex items-center justify-center text-base shadow-lg shadow-violet-900/50">
      🏥
    </div>
    <h1 class="text-white font-bold text-base tracking-tight">Elderly Care Support</h1>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto px-3 py-5 space-y-1">

    <!-- Dashboard -->
    <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all group">
      <div class="w-8 h-8 rounded-lg bg-white/5 group-hover:bg-violet-600/20 flex items-center justify-center transition-colors">
        <svg class="w-4 h-4 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
      </div>
      <span class="text-sm font-medium">Dashboard</span>
    </a>

    <!-- Divider label -->
    <div class="px-3 pt-4 pb-1">
      <span class="text-[10px] font-bold uppercase tracking-widest text-gray-600">Configuration</span>
    </div>

    <!-- Settings Dropdown -->
    <li class="list-none">
      <button onclick="toggleDropdown(this)"
        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all group cursor-pointer">
        <div class="w-8 h-8 rounded-lg bg-white/5 group-hover:bg-violet-600/20 flex items-center justify-center transition-colors">
          <svg class="w-4 h-4 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/>
          </svg>
        </div>
        <span class="text-sm font-medium flex-1 text-left">Settings</span>
        <svg id="settings-arrow" class="w-3.5 h-3.5 text-gray-600 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>

      <!-- Dropdown -->
      <ul id="dropdown" class="mt-1 ml-4 pl-3 border-l border-white/5 space-y-0.5 hidden">

        @if (User.IsInRole("Admin") && User.Identity.IsAuthenticated)
        {
          <li>
            <a href="@Url.Action("Index", "Role")"
               onclick="setActive(this)"
               class="sidebar-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-500 hover:text-white hover:bg-white/5 transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
              </svg>
              Roles
            </a>
          </li>
        }

        <li>
          <a href="#"
             onclick="setActive(this)"
             class="sidebar-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-500 hover:text-white hover:bg-white/5 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            Permissions
          </a>
        </li>

        <li>
          <a href="#"
             onclick="setActive(this)"
             class="sidebar-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-500 hover:text-white hover:bg-white/5 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            Users
          </a>
        </li>

      </ul>
    </li>

  </nav>

  <!-- User Profile -->
  <div class="px-3 py-4 border-t border-white/5">
    <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition cursor-pointer">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500 to-violet-800 flex items-center justify-center text-white text-xs font-bold shadow shadow-violet-900/50">
        A
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-white text-sm font-semibold truncate">Admin</div>
        <div class="text-gray-500 text-xs truncate">admin@elderlycare.com</div>
      </div>
      <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/>
      </svg>
    </div>
  </div>

</aside>

<script>
  function toggleDropdown(btn) {
    const dropdown = document.getElementById('dropdown');
    const arrow = document.getElementById('settings-arrow');
    const isHidden = dropdown.classList.contains('hidden');
    dropdown.classList.toggle('hidden', !isHidden);
    arrow.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
    btn.classList.toggle('text-white', isHidden);
    btn.classList.toggle('bg-white/5', isHidden);
  }

  function setActive(el) {
    document.querySelectorAll('.sidebar-link').forEach(link => {
      link.classList.remove('text-white', 'bg-violet-600/20', '!text-violet-400');
    });
    el.classList.add('text-white', 'bg-violet-600/20', '!text-violet-400');
  }
</script>