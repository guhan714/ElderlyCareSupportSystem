@model ElderlyCareSupportSystem.Application.Modules.Role.Models.RoleViewModel

@{
  Layout = "_Layout";
}

<div class="bg-white rounded-2xl shadow-lg w-full overflow-hidden">

  <!-- Header -->
  <div class="bg-gradient-to-r from-violet-600 to-violet-800 px-8 py-6 flex items-center gap-4">
    <div class="w-11 h-11 bg-white/15 rounded-xl flex items-center justify-center text-2xl">🛡️</div>
    <div>
      <div class="text-white font-bold text-lg">Role</div>
    </div>
  </div>

  <!-- Form Body -->

  <div class="px-8 py-7 flex flex-col gap-5">
    <form id="RoleUpdateForm">
      @Html.AntiForgeryToken()
      <div class="grid grid-cols-2 gap-4">
        @Html.HiddenFor(model => model.Id)
        <!-- Code -->
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide flex items-center gap-1.5">
            Code <span class="text-red-500">*</span>
          </label>
          @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @id = "Code", @maxlength = "20", @class = "bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-800 outline-none placeholder-gray-300 focus:border-violet-500 focus:ring-3 focus:ring-violet-100 transition" } })

        </div>

        <!-- Name -->
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">
            Name <span class="text-red-500">*</span>
          </label>
          @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @id = "Name", @maxlength = "50", @class = "bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-800 outline-none placeholder-gray-300 focus:border-violet-500 focus:ring-3 focus:ring-violet-100 transition" } })
        </div>
      </div>

      <!-- Description -->
      <div class="flex flex-col gap-1.5 mt-3">
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Description</label>
        @Html.TextAreaFor(model => model.Description, new { @id = "Description", @rows = "3", @maxlength = "250", @placeholder = "Describe the responsibilities and scope of this role…", @class = "bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-800 outline-none placeholder-gray-300 focus:border-violet-500 focus:ring-3 focus:ring-violet-100 transition resize-none" })
      </div>

      <hr class="border-gray-100"/>

      <!-- IsActive Toggle -->
      <div class="flex items-center justify-between bg-gray-50 border border-gray-200 rounded-xl px-4 py-3.5 mt-3">
        <div>
          <div class="text-sm font-semibold text-gray-800">Active Status</div>
          <div class="text-xs text-gray-400 mt-0.5">Inactive roles cannot be assigned to users</div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          @Html.CheckBoxFor(model => model.IsActive, new { @id = "IsActive", @class = "sr-only peer" })
          <div
            class="w-11 h-6 bg-gray-300 rounded-full peer peer-checked:bg-violet-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-5"></div>
        </label>
      </div>

      <!-- Preview -->
      <div id="preview" class="hidden bg-violet-50 border border-dashed border-violet-300 rounded-xl px-4 py-3">
        <div class="text-[10px] font-bold uppercase tracking-widest text-violet-500 mb-2">Preview</div>
        <div class="flex items-center gap-2 flex-wrap">
          <span id="preview-code"
                class="font-mono text-xs bg-violet-100 text-violet-700 font-semibold px-2.5 py-1 rounded"></span>
          <span id="preview-name" class="text-sm font-semibold text-gray-700"></span>
        </div>
      </div>
    </form>

    <!-- Buttons -->
    <div class="flex justify-end gap-3 pt-1">
      <a
        type="button"
        href="@Url.Action("Index")"
        class="px-5 py-2.5 rounded-lg border border-gray-200 text-gray-500 text-sm font-semibold hover:border-violet-300 hover:text-violet-600 hover:bg-violet-50 transition cursor-pointer">
        Cancel
      </a>
      <button
        id="submit-btn"
        type="button"
        class="px-6 py-2.5 rounded-lg bg-gradient-to-r from-violet-600 to-violet-800 text-white text-sm font-bold shadow-md hover:-translate-y-0.5 hover:shadow-violet-300 hover:shadow-lg transition cursor-pointer">
        Save
      </button>
    </div>

  </div>
</div>

@section Scripts{
  <script src="~/js/Modules/Role/edit.js"></script>

  <script>
    $("#submit-btn").click(function (e) {
      e.preventDefault();
      startLoader();
      const existingRole = {
        name: '@Model.Name',
        description: '@Model.Description',
        isActive: '@Model.IsActive' === 'True'
      };
      const role = getRoleDetails();
      const valid = validateRole(role, existingRole);
      if (!valid.success) {
        stopLoader();
        errorAlert(valid.message);
        return false;
      }
      updateRole('@Url.Action("Edit", "Role")', role);
    });


    $('#IsActive').click(function (e) {

      const isActive = $(this).is(':checked');
      if (!isActive) {
        Swal.fire({
          title: 'Are you sure?',
          text: "You won't be able to revert this!",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#3085d6',
          cancelButtonColor: '#d33',
          confirmButtonText: 'Yes!'
        }).then(async (result) => {
          if (result.isConfirmed) {
            $(this).prop('checked', false);
          }
          else {
            $(this).prop('checked', true);
          }
        });
      }
    });
  </script>
}